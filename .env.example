# llm-tg-bot-nextjs environment
#
# Runtime configuration (LLM connection, model, prompts, feature settings)
# lives in DB-backed Settings edited via the dashboard — not in env vars.
# Env is bootstrap-only. Every variable also accepts a `<NAME>_FILE` variant
# pointing at a file whose contents are used instead (Docker secrets), e.g.
# DATABASE_URL_FILE=/run/secrets/database_url.

# --- Persistence (required bootstrap) ---
# Postgres (with pgvector) connection string.
# For local (non-Docker) dev, point this at your own Postgres. Under
# `docker compose`, DATABASE_URL is built from the POSTGRES_* vars below and
# targets the bundled `db` service, so you can leave this unset there.
DATABASE_URL=postgres://bot:bot@localhost:5432/bot

# --- Docker compose ---
# Bundled Postgres credentials + published app port.
# POSTGRES_USER=bot
# POSTGRES_PASSWORD=bot
# POSTGRES_DB=bot
# POSTGRES_PORT=5432
# PORT=3200
# Host directory Postgres persists into (bind-mounted).
# PG_DATA_DIR=./data/pg

# --- Runtime ---
# IANA timezone for scheduled work (default UTC).
# TZ=Europe/Berlin
