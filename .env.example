# llm-tg-bot-nextjs environment
#
# All variables also accept a `<NAME>_FILE` variant pointing at a file whose
# contents are used instead (Docker secrets), e.g. BOT_TOKEN_FILE=/run/secrets/bot_token.

# --- Telegram ---
# Required for the bot to receive/send messages.
BOT_TOKEN=your_telegram_bot_token_here
# Optional shared secret for validating incoming Telegram webhook calls.
# TELEGRAM_WEBHOOK_SECRET=

# --- LLM (OpenAI-compatible) ---
# Required: chat completions base URL (e.g. https://your-host/v1).
LLM_BASE_URL=https://your-llm-host/v1
# Optional: API key for authenticated endpoints. Local servers can leave unset.
# LLM_API_KEY=
# Optional: default model id (dashboard settings override this).
# LLM_MODEL=
# Optional: separate embedding host; falls back to LLM_BASE_URL / LLM_API_KEY.
# EMBEDDING_BASE_URL=
# EMBEDDING_API_KEY=
# Optional: separate image-generation host; falls back to LLM_BASE_URL / LLM_API_KEY.
# IMAGE_GENERATION_BASE_URL=
# IMAGE_GENERATION_API_KEY=

# --- Persistence ---
# Required: Postgres (with pgvector) connection string.
# For local (non-Docker) dev, point this at your own Postgres. Under
# `docker compose`, DATABASE_URL is built from the POSTGRES_* vars below and
# targets the bundled `db` service, so you can leave this unset there.
DATABASE_URL=postgres://bot:bot@localhost:5432/bot

# --- Docker compose ---
# Bundled Postgres credentials + published app port.
# POSTGRES_USER=bot
# POSTGRES_PASSWORD=bot
# POSTGRES_DB=bot
# POSTGRES_PORT=5432
# PORT=3200
# Host directory Postgres persists into (bind-mounted).
# PG_DATA_DIR=./data/pg

# --- Optional integrations ---
# Web search via Tavily (https://tavily.com).
# TAVILY_API_KEY=

# --- Runtime ---
# IANA timezone for scheduled work (default UTC).
# TZ=Europe/Berlin
# Host directory for browser-agent downloads.
# DOWNLOADS_DIR=./downloads
# Logging verbosity: ERROR (default) | DEBUG
# LOGGING_LEVEL=ERROR
